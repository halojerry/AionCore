// example_framework.dot — 模型框架图 (Graphviz)
// 渲染: dot -Tpdf example_framework.dot -o out_framework.pdf
//       dot -Tpng -Gdpi=600 example_framework.dot -o out_framework.png
// 设计: rankdir=LR 分层; 圆角框; 配色用 Okabe-Ito; rank=same 对齐同层。
digraph framework {
    rankdir = LR;
    bgcolor = "white";
    fontname = "Arial";
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
          color="#333333", penwidth=1.0, margin="0.12,0.07"];
    edge [fontname="Arial", fontsize=9, color="#555555", penwidth=1.0,
          arrowsize=0.7];

    // 输入
    input  [label="Input\n(image / signal)", fillcolor="#56B4E9"];

    // 编码器分支
    enc1   [label="Backbone\nEncoder", fillcolor="#009E73"];
    enc2   [label="Feature\nPyramid",  fillcolor="#009E73"];

    // 核心模块
    attn   [label="Attention\nFusion", fillcolor="#E69F00"];
    head   [label="Task\nHead",        fillcolor="#E69F00"];

    // 输出与损失
    out    [label="Prediction", fillcolor="#CC79A7"];
    loss   [label="Loss\n(supervision)", shape=ellipse, fillcolor="#F0E442"];

    input -> enc1 -> enc2 -> attn -> head -> out;
    enc1 -> attn [style=dashed, label="skip"];
    out  -> loss [dir=both, style=dotted];

    { rank=same; enc1; enc2; }
}
